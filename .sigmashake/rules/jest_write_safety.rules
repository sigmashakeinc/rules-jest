# jest_write_safety.rules
# Technology: jest | Capability: write

rule jest-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_jest_PATTERN"
  MESSAGE "Blocked an unsafe pattern in jest. Use the recommended best practices for 2025/2026."
}

rule jest-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_jest_API"
  MESSAGE "You are using an outdated API for jest. Please upgrade to the newer API."
}
